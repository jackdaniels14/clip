{
  "name": "stoke-video-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Stoke Mountain Video System",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "stripe": "^14.14.0",
    "node-media-server": "^2.6.3",
    "uuid": "^9.0.1",
    "date-fns": "^3.3.1",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.9",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.17",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "firebase-functions-test": "^3.1.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2"
  },
  "private": true
}
